@startuml M3L
package structure{
    class Lattice{
        -acell: float
        -bcell: float
        -ccell: float
        -a1: float
        -a2: float
        -a3: float
        -b1: float
        -b2: float
        -b3: float
        -c1: float
        -c2: float
        -c3: float
        setVolume()
        getVolume()
        setAcell()
        getAcell()
        setBcell()
        getBcell()
        setCcell()
        getCcell()
    }
    class System{
        -natoms: int
        setXYZ()
        convertUnits()
        getNatoms()
    }
    System --|> Lattice
}
@enduml